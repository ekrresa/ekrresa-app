{
  "name": "ekrresa.com",
  "version": "1.0.0",
  "private": true,
  "description": "Ochuko Ekrresa's personal website",
  "keywords": [],
  "license": "MIT",
  "author": "Ochuko Ekrresa - Software Engineer",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "main": "index.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "npm run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "eslint .",
    "lint:cache": "eslint . --cache",
    "lint:fix": "eslint . --fix",
    "types": "tsc"
  },
  "dependencies": {
    "@phosphor-icons/react": "2.1.10",
    "clipboardy": "5.3.1",
    "clsx": "2.1.1",
    "core-js": "3.49.0",
    "motion": "12.42.2",
    "react": "19.2.7",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.7",
    "react-server-dom-webpack": "19.2.7",
    "rwsdk": "1.5.7",
    "safe-mdx": "1.11.5",
    "sugar-high": "1.2.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.33.2",
    "@cloudflare/workers-types": "4.20260405.1",
    "@content-collections/core": "0.14.3",
    "@content-collections/markdown": "0.1.4",
    "@content-collections/vite": "0.2.9",
    "@eslint/css": "1.3.0",
    "@eslint/js": "10.0.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "~25.3.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.4.1",
    "eslint-plugin-better-tailwindcss": "4.6.1",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "oxfmt": "^0.51.0",
    "tailwindcss": "4.3.2",
    "tailwindcss-react-aria-components": "2.2.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.60.1",
    "vite": "~8.1.4",
    "wrangler": "4.85.0",
    "zod": "4.3.6"
  }
