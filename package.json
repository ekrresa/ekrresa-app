    "@types/react-dom": "19.2.3",
    "oxfmt": "^0.51.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-react-aria-components": "2.1.0",
    "typescript": "6.0.2",
    "vite": "~7.3.2",
    "wrangler": "4.80.0",
    "zod": "4.3.6"
  }
