{
  "name": "@redwoodjs/starter",
  "version": "1.0.0",
  "private": true,
  "description": "A bare-bones RedwoodSDK starter",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "npm run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "types": "tsc"
  },
  "dependencies": {
    "lucide-react": "1.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-server-dom-webpack": "19.2.6",
    "rwsdk": "1.2.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.31.0",
    "@cloudflare/workers-types": "4.20260405.1",
    "@content-collections/core": "0.14.3",
    "@content-collections/markdown": "0.1.4",
    "@content-collections/vite": "0.2.9",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "~25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "oxfmt": "^0.51.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.2",
    "vite": "~7.3.2",
    "wrangler": "4.80.0",
    "zod": "4.3.6"
  }
}
